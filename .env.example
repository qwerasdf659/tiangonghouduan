# 餐厅积分抽奖系统 - 环境变量配置示例
# 使用说明：复制此文件为.env，并填写实际的配置值

# 服务器配置
NODE_ENV=development
PORT=3000
WS_PORT=10081
TZ=Asia/Shanghai

# 数据库配置
DB_HOST=your_database_host
DB_PORT=3306
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_NAME=restaurant_points_dev

# JWT配置
JWT_SECRET=your_jwt_secret_key_at_least_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_key_at_least_64_chars
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# 加密配置
ENCRYPTION_KEY=your_encryption_key_32_chars

# Redis配置（统一使用REDIS_URL，不再支持REDIS_HOST/PORT分离配置）
REDIS_URL=redis://localhost:6379

# Sealos对象存储配置
SEALOS_ENDPOINT=https://objectstorageapi.bja.sealos.run
SEALOS_INTERNAL_ENDPOINT=http://object-storage.objectstorage-system.svc.cluster.local
SEALOS_BUCKET=your_bucket_name
SEALOS_ACCESS_KEY=your_access_key
SEALOS_SECRET_KEY=your_secret_key
SEALOS_REGION=bja

# 🔴 微信小程序配置（API#1.2 微信授权一键登录必需）
# 获取方式：
# 1. 登录微信公众平台 https://mp.weixin.qq.com/
# 2. 进入"开发" → "开发管理" → "开发设置"
# 3. 复制AppID和AppSecret
# ⚠️ 注意：必须填写实际的微信小程序AppID和AppSecret，否则微信授权登录功能无法使用
WX_APPID=wxXXXXXXXXXXXXXXXX
WX_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# OCR服务配置
OCR_PROVIDER=baidu_ocr
OCR_API_KEY=your_baidu_ocr_api_key
OCR_SECRET_KEY=your_baidu_ocr_secret_key

# 短信验证码服务配置
SMS_PROVIDER=aliyun_sms
SMS_ACCESS_KEY=your_aliyun_sms_access_key
SMS_SECRET_KEY=your_aliyun_sms_secret_key
SMS_SIGN_NAME=餐厅积分系统
SMS_TEMPLATE_CODE=SMS_123456789

# 服务器地址配置
INTERNAL_BASE_URL=http://localhost:3000
INTERNAL_WS_URL=ws://localhost:8080
PUBLIC_BASE_URL=https://your-domain.com
PUBLIC_WS_URL=wss://your-domain.com/ws

# 系统配置
LOG_LEVEL=info
MAX_FILE_SIZE=10485760
ENABLE_CORS=true
ENABLE_RATE_LIMIT=true

# 数据管理配置
# 启用定时数据清理 Job（每天凌晨 3:10 自动清理过期数据）
ENABLE_DATA_CLEANUP=true
# 清档后自动重建的超管手机号（模式一：上线前清档使用）
SUPER_ADMIN_MOBILE=13612227910

# 抽奖系统配置
LOTTERY_COST_POINTS=30
DAILY_LOTTERY_LIMIT=10
NEW_USER_POINTS=1000

# 积分系统配置
PHOTO_POINTS_RATE=10
MIN_POINTS_AWARD=50
MAX_POINTS_AWARD=2000

# Anthropic API 配置（用于AI功能）
# 获取方式：访问 https://console.anthropic.com/ 获取API密钥
ANTHROPIC_AUTH_TOKEN=your_anthropic_api_token_here
ANTHROPIC_BASE_URL=https://api.anthropic.com
