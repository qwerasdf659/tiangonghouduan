# 天工商户营销平台 - 环境变量配置示例
# 使用说明：复制此文件为.env，并填写实际的配置值

# 服务器配置
NODE_ENV=development
PORT=3000
WS_PORT=10081
TZ=Asia/Shanghai

# 数据库配置
DB_HOST=your_database_host
DB_PORT=3306
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_NAME=restaurant_points_dev

# JWT配置
JWT_SECRET=your_jwt_secret_key_at_least_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_key_at_least_64_chars
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# 加密配置
ENCRYPTION_KEY=your_encryption_key_32_chars

# Redis配置（统一使用REDIS_URL，不再支持REDIS_HOST/PORT分离配置）
REDIS_URL=redis://localhost:6379

# Sealos对象存储配置
SEALOS_ENDPOINT=https://objectstorageapi.bja.sealos.run
SEALOS_INTERNAL_ENDPOINT=http://object-storage.objectstorage-system.svc.cluster.local
SEALOS_BUCKET=your_bucket_name
SEALOS_ACCESS_KEY=your_access_key
SEALOS_SECRET_KEY=your_secret_key
SEALOS_REGION=bja

# 🔴 微信小程序配置（API#1.2 微信授权一键登录必需）
# 获取方式：
# 1. 登录微信公众平台 https://mp.weixin.qq.com/
# 2. 进入"开发" → "开发管理" → "开发设置"
# 3. 复制AppID和AppSecret
# ⚠️ 注意：必须填写实际的微信小程序AppID和AppSecret，否则微信授权登录功能无法使用
WX_APPID=wxXXXXXXXXXXXXXXXX
WX_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# 短信验证码服务配置（腾讯云短信 Tencent Cloud SMS）
# SMS_PROVIDER 必须为 tencent，代码仅识别该值；留空则验证码只存 Redis、不真正下发
SMS_PROVIDER=tencent
SMS_ACCESS_KEY=your_tencent_cloud_secret_id
SMS_SECRET_KEY=your_tencent_cloud_secret_key
SMS_SIGN_NAME=your_sms_sign_name
SMS_TEMPLATE_CODE=your_template_id
SMS_APP_ID=your_sms_sdk_app_id
SMS_REGION=ap-guangzhou

# 人机验证（腾讯云天御验证码 Captcha，P1.5 用户端发码前置校验）
# 非生产环境默认放行（跳过校验）；生产环境强制校验票据。SecretId/SecretKey 复用上面的 SMS_ACCESS_KEY/SMS_SECRET_KEY（同一腾讯云账号）
CAPTCHA_APP_ID=your_captcha_app_id
CAPTCHA_APP_SECRET_KEY=your_captcha_app_secret_key
# 天御灰度/应急开关（O5）：true=强制启用(含非生产) / false=强制关闭(含生产,应急降级) / 留空=按NODE_ENV(生产启用,非生产放行)
CAPTCHA_ENABLED=
# 天御服务异常时降级策略：true=fail-open 放行+频控兜底（默认），false=fail-close 拒绝发码
CAPTCHA_FAIL_OPEN=true
# 天御接口地域（可选，默认 ap-guangzhou）
CAPTCHA_REGION=ap-guangzhou

# 管理端登录加固（P0.6 失败锁定 + IP 白名单）
# 同手机号连续登录失败达到阈值后锁定一段时间，防爆破/撞库
ADMIN_LOGIN_MAX_FAIL=5
ADMIN_LOGIN_LOCK_MINUTES=15
# 管理端 IP 白名单（逗号分隔；留空=不启用。管理员“到处登”出口 IP 不固定，默认不启用）
ADMIN_IP_ALLOWLIST=

# 服务器地址配置
INTERNAL_BASE_URL=http://localhost:3000
PUBLIC_BASE_URL=https://your-domain.com

# 系统配置
LOG_LEVEL=info
MAX_FILE_SIZE=10485760
ENABLE_CORS=true
# 限流阈值（统一前缀 RATE_LIMIT_*，唯一真相源）；测试环境关闭限流用 DISABLE_RATE_LIMITER=true
# public_read：公开只读接口宽松档（campaigns/active + system/config + app-version）
RATE_LIMIT_PUBLIC_READ_MAX=300
# global：全局兜底（所有 /api/ 接口，登录按 user、未登录按 ip）
RATE_LIMIT_GLOBAL_MAX=600
# window：限流时间窗口（毫秒）
RATE_LIMIT_WINDOW_MS=60000

# 数据管理配置
# 启用定时数据清理 Job（每天凌晨 3:10 自动清理过期数据）
ENABLE_DATA_CLEANUP=true
# 清档后自动重建的超管手机号（模式一：上线前清档使用）
SUPER_ADMIN_MOBILE=13612227910

# 抽奖系统配置
LOTTERY_COST_POINTS=30
DAILY_LOTTERY_LIMIT=10
# 积分规则真相源在 system_settings(category='points')：points_award_ratio=1（1元=1积分），非环境变量
