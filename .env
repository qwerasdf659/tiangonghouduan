# ===== 人机验证（腾讯云天御验证码 Captcha，P1.5）2026-06-18 新增 =====
# ⚠️ 待填真实值：CAPTCHA_APP_ID / CAPTCHA_APP_SECRET_KEY 需在腾讯云天御验证码控制台创建后填入
# 非生产环境默认放行（跳过校验），生产环境强制校验。SecretId/SecretKey 复用 SMS_ACCESS_KEY/SMS_SECRET_KEY
CAPTCHA_APP_ID=199729942
CAPTCHA_APP_SECRET_KEY=XsFZgQm3XaYV9VxAyJVnN34Et
# 天御灰度/应急开关（O5）：true=强制启用 / false=强制关闭(应急降级) / 留空=按NODE_ENV默认
CAPTCHA_ENABLED=true
CAPTCHA_FAIL_OPEN=true
CAPTCHA_REGION=ap-guangzhou

# ===== 管理端登录加固（P0.6 失败锁定 + IP 白名单）2026-06-18 新增 =====
ADMIN_LOGIN_MAX_FAIL=5
ADMIN_LOGIN_LOCK_MINUTES=15
# 管理员“到处登”出口 IP 不固定，默认不启用（留空）；如需启用填逗号分隔的 IP 列表
ADMIN_IP_ALLOWLIST=

# 活动专属预算到期清零任务开关（水晶奖品倍率活动 §18.5 防囤积套利，true=启用每日凌晨1点清零）
ENABLE_EVENT_BUDGET_EXPIRY=true
