# 依赖包 - 用户要求提交node_modules
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 环境变量文件（保留示例）
.env.local
.env.production

# 日志文件
logs/
*.log

# 临时文件
.tmp/
.cache/
*.tmp
*.temp

# 系统文件
.DS_Store
Thumbs.db

# IDE文件
.vscode/settings.json
.idea/
*.swp
*.swo

# 构建文件
dist/
build/

# 测试覆盖率报告
coverage/

# 上传文件目录
uploads/
images/uploads/

# 备份文件
*.backup
*.bak

# 路由归档目录（TR-010规范）
routes/v4/_archived/

# 操作系统生成的文件
*.pid
*.lock

# 应用日志文件
app.log
server.log

# 临时打包文件
*.tar.gz
*.bundle

# Cursor IDE配置（但保留规则文档）
.cursor/*
!.cursor/rules/
!.cursor/rules/*

# Claude AI 本地配置（删32 否决删除：文件保留本地，仅不入库）
.claude/
.clauderc

# VSIX 插件安装包（与项目无关的二进制，不入库）
*.vsix

# 行政区划数据快照（拍板 14：保留文件，仅不入库）
data/pcas-code.json

# 禁止手动迁移脚本（强制规范 - 2026-01-04拍板）
# 所有数据库变更必须走标准迁移流程，无例外
migrations/manual/
**/manual/*.sql

# Environment variables
.env
# .env 命令行修改前的时间戳备份（仅本地留存，不入库）
.env.bak.*

# 备份目录整体不入库（删33：本地/对象存储留存，git 不承载数据备份）
backups/
dump.rdb
# Redis AOF 持久化产物（开启 appendonly 后生成于运行目录，不入库）
appendonlydir/

# 测试结果输出
test-results/
